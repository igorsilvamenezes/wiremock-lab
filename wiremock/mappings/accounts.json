{
  "mappings": [
    {
      "name": "GET account by ID - success",
      "request": {
        "method": "GET",
        "urlPattern": "/api/accounts/([a-zA-Z0-9-]+)"
      },
      "response": {
        "status": 200,
        "headers": {
          "Content-Type": "application/json",
          "X-Correlation-Id": "{{randomValue type='UUID'}}"
        },
        "jsonBody": {
          "id": "{{request.pathSegments.[2]}}",
          "owner": "João Silva",
          "agency": "0001",
          "accountNumber": "12345-6",
          "type": "CORRENTE",
          "balance": 15000.00,
          "status": "ACTIVE",
          "currency": "BRL"
        },
        "transformers": ["response-template"]
      }
    },
    {
      "name": "GET account - not found",
      "request": {
        "method": "GET",
        "url": "/api/accounts/not-found"
      },
      "response": {
        "status": 404,
        "headers": {
          "Content-Type": "application/json"
        },
        "jsonBody": {
          "error": "ACCOUNT_NOT_FOUND",
          "message": "Account not found",
          "timestamp": "{{now format='yyyy-MM-dd\\'T\\'HH:mm:ss\\'Z\\''}}"
        },
        "transformers": ["response-template"]
      }
    }
  ]
}